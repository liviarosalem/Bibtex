@article{dias2023a,
  title = {The {{Relaxed Eddy Accumulation Method Over}} the {{Amazon Forest}}: {{The Importance}} of {{Flux Strength}} on {{Individual}} and {{Aggregated Flux Estimates}}},
  shorttitle = {The {{Relaxed Eddy Accumulation Method Over}} the {{Amazon Forest}}},
