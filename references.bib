  keywords = {ATTO project,notion,REA method,Roughness sublayer},
  file = {D:\ZOTERO\storage\QUVNA5KA\Dias et al. - 2023 - The Relaxed Eddy Accumulation Method Over the Amazon Forest The Importance of Flux Strength on Indi.pdf}
}

