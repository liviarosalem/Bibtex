@book{
  title = {The {{State}} of {{Food Security}} and {{Nutrition}} in the {{World}} 2025. {{Addressing}} High Food Price Inflation for Food Security and Nutrition},
  author = {{FAO} and {IFAD} and {UNICEF} and {WFP} and {WHO}},
  year = 2025,
  series = {The {{State}} of {{Food Security}} and {{Nutrition}} in the {{World}} ({{SOFI}})},
  number = {2025},
  publisher = {FAO; IFAD; UNICEF; WFP; WHO},
  address = {Rome, Italy},
  doi = {10.4060/cd6008en},
  urldate = {2025-10-23},
  abstract = {While some progress and recovery have been made in recent years, the world is still above pre-COVID-19 pandemic levels and far from eradicating hunger and food insecurity by 2030 (SDG Target 2.1). Similarly, despite some progress in the global nutrition targets, the world is not on track to achieve SDG Target 2.2. Among other factors, persistent food price inflation has slowed this momentum.The State of Food Security and Nutrition in the World 2025 highlights how elevated inflation in many countries has undermined purchasing power and, especially among low-income populations, access to healthy diets. The report documents how high food price inflation is associated with increases in food insecurity and child malnutrition. Vulnerable groups, including low-income households, women, and rural communities, can be particularly affected by food price inflation, risking setbacks in the fight against hunger and malnutrition.In response to these challenges and to prevent future price shocks, the report examines policy measures adopted by countries, and outlines what is necessary going forwards. It stresses the importance of coherent implementation of fiscal and monetary policies to stabilize markets, promote open and resilient trade, and protect vulnerable populations. Additionally, it calls for better data systems and sustained investment in resilient agrifood systems to build long-term food security and nutrition. These coordinated actions are vital to reignite progress towards ending hunger and malnutrition by 2030.},
  copyright = {FAO},
  isbn = {978-92-5-139937-8},
  langid = {english},
  keywords = {costs,fiscal policies,food affordability,food insecurity,food prices,food security,healthy diets,hunger,impact assessment,inflation,monetary policies,trade policies}
}

