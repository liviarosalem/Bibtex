@article{
  title = {Simulation of the {{Scalar Transport}} above and within the {{Amazon Forest Canopy}}},
  author = {{Serra-Neto}, Edivaldo M. and Martins, Hardiney S. and {Dias-J{\'u}nior}, Cl{\'e}o Q. and Santana, Raoni A. and Brondani, Daiane V. and Manzi, Ant{\^o}nio O. and {de Ara{\'u}jo}, Alessandro C. and Teixeira, Paulo R. and S{\"o}rgel, Matthias and Mortarini, Luca},
  year = 2021,
