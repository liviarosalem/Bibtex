  shorttitle = {Hydrological Services in the {{Atlantic Forest}}, {{Brazil}}},
  author = {Taffarello, Denise and Calijuri, Maria do Carmo and Viani, Ricardo A. Gorne and Marengo, Jos{\'e} A. and Mendiondo, Eduardo Mario},
  year = 2017,
