@article{
  title = {{Precipita\c c\~ao efetiva em diferentes forma\c c\~oes florestais na floresta nacional de ipanema}},
  author = {Tonello, Kelly Cristina and Gasparoto, Esthevan Augusto Goes and Shinzato, Emily Tsiemi and Valente, Roberta de Oliveira Averna and Dias, Herly Carlos Teixeira},
  year = 2014,
  month = apr,
  journal = {Revista \'Arvore},
  volume = {38},
  pages = {383--390},
  publisher = {Sociedade de Investiga\c c\~oes Florestais},
  issn = {0100-6762, 0100-6762, 1806-9088},
  doi = {10.1590/S0100-67622014000200020},
  urldate = {2021-07-02},
  abstract = {O presente trabalho foi conduzido na Floresta Nacional de Ipanema, unidade de conserva\c c\~ao de uso sustent\'avel localizada no munic\'ipio de Iper\'o-SP, com o objetivo de quantificar e comparar as fra\c c\~oes de precipita\c c\~ao efetiva e intercepta\c c\~ao da chuva em tr\^es povoamentos florestais distintos, sendo eles: Eucalyptus cloeziana, Pinus caribea var. hondurensis e Floresta Estacional Semidecidual. Para tanto, realizou-se o monitoramento das vari\'aveis precipita\c c\~ao interna, escoamento pelo tronco, intercepta\c c\~ao e precipita\c c\~ao em aberto em cada forma\c c\~ao florestal, ao longo do per\'iodo de novembro de 2009 \`a maio de 2010. O estudo revelou a precipita\c c\~ao efetiva de 86,2\%, 85,0\% e 77,2\%; intercepta\c c\~ao de 13,8\%, 15,0\% e 22,8\% em rela\c c\~ao \`a precipita\c c\~ao em aberto em Eucalyptus cloeziana, Pinus caribea var. hondurensis e Floresta Estacional Semidecidual, respectivamente. A influ\^encia dos povoamentos na distribui\c c\~ao da chuva apresentou diferen\c ca significativa somente para o processo de intercepta\c c\~ao entre Floresta Estacional Semidecidual e os demais.},
  langid = {portuguese},
  keywords = {Escoamento pelo tronco,Hidrologia florestal,Precipitacao interna},
  file = {D\:\\ZOTERO\\storage\\GD2DNGQA\\Tonello et al. - 2014 - Precipitação efetiva em diferentes formações flore.pdf;D\:\\ZOTERO\\storage\\26BX5F2Z\\7XcLhWJmgB6wYrvqLfRytpP.html}
}

@article{
  title = {{Precipita\c c\~ao incidente e fluxo de atravessamento das chuvas em tr\^es est\'agios sucessionais de floresta atl\^antica no maci\c co da Pedra Branca, Rio de Janeiro}},
  author = {Togashi, Henrique F{\"u}rstenau and Montezuma, Rita de C{\'a}ssia Martins and Leite, Adriana Filgueira},
  year = 2012,
  month = oct,
  journal = {Revista \'Arvore},
  volume = {36},
  pages = {907--918},
  publisher = {Sociedade de Investiga\c c\~oes Florestais},
  issn = {0100-6762, 0100-6762, 1806-9088},
  doi = {10.1590/S0100-67622012000500013},
  urldate = {2021-07-02},
  abstract = {S\~ao apresentados os resultados de fracionamento da precipita\c c\~ao de chuva em tr\^es tipologias vegetais atrav\'es dos fluxos de atravessamento e precipita\c c\~ao incidente em estudo realizado na sub-bacia do Ca\c cambe, maci\c co da Pedra Branca, Rio de Janeiro. No per\'iodo de 04/11/09 a 04/11/10, foram realizadas 27 coletas ap\'os os eventos de chuva. Utilizaram-se 12 pluvi\^ometros em uma \'area de floresta secund\'aria avan\c cada, seis em uma capoeira e seis na borda entre as tipologias. Os resultados de fluxo de atravessamento, 89\% na borda, 94\% em mata secund\'aria inicial e 75\% em floresta secund\'aria avan\c cada, est\~ao de acordo com valores m\'edios da Floresta Atl\^antica. Houve aumento de intercepta\c c\~ao com o avan\c co do est\'agio sucessional, o que sugere a import\^ancia da preserva\c c\~ao florestal para garantir intercepta\c c\~ao mais eficiente da \'agua da chuva, em especial em uma cidade sujeita a alagamentos, como o Rio de Janeiro.},
  langid = {portuguese},
  keywords = {Floresta Atlantica,Fluxo de atravessamento,Precipitacao incidente},
  file = {D\:\\ZOTERO\\storage\\BKRHTQHF\\Togashi et al. - 2012 - Precipitação incidente e fluxo de atravessamento d.pdf;D\:\\ZOTERO\\storage\\T2UB8NRE\\abstract.html}
}

@article{
  title = {{Precipita\c c\~ao efetiva e intercepta\c c\~ao da chuva em um fragmento florestal com diferentes est\'agios de regenera\c c\~ao}},
  author = {Lorenzon, Alexandre Sim{\~o}es and Dias, Herly Carlos Teixeira and Leite, H{\'e}lio Garcia},
  year = 2013,
  month = aug,
  journal = {Revista \'Arvore},
  volume = {37},
  pages = {619--627},
  publisher = {Sociedade de Investiga\c c\~oes Florestais},
  issn = {0100-6762, 0100-6762, 1806-9088},
  doi = {10.1590/S0100-67622013000400005},
  urldate = {2021-07-02},
  abstract = {Este trabalho teve por objetivo avaliar a precipita\c c\~ao efetiva e a intercepta\c c\~ao da chuva em um fragmento de Floresta Estacional Semidecidual em est\'agio inicial e avan\c cado de regenera\c c\~ao no Munic\'ipio de Vi\c cosa, Minas Gerais, no per\'iodo de agosto de 2009 a fevereiro de 2011. Foram demarcadas seis parcelas, tr\^es na \'area de regenera\c c\~ao inicial e tr\^es na \'area de regenera\c c\~ao avan\c cada. Para quantificar a precipita\c c\~ao interna e o escoamento pelo tronco, foram instalados 25 pluvi\^ometros em cada parcela e coletores nas \'arvores com circunfer\^encia 15 cm. Al\'em disso, um pluvi\^ometro foi instalado em local aberto para quantificar a precipita\c c\~ao em aberto, que no per\'iodo estudado foi igual a 1.509,96 mm. Em m\'edia, 85,08 e 74,93\% da precipita\c c\~ao em aberto, respectivamente, no est\'agio inicial e avan\c cado de regenera\c c\~ao, chegam ao solo via precipita\c c\~ao efetiva. A intercepta\c c\~ao pelo dossel florestal foi maior na \'area avan\c cada do que na \'area inicial de regenera\c c\~ao, correspondendo, respectivamente, a 25,07 e 14,92\% da precipita\c c\~ao em aberto, o que sugere que \'areas mais densamente povoadas interceptam maior quantidade de chuva e, consequentemente, geram menor precipita\c c\~ao efetiva.},
  langid = {portuguese},
  keywords = {Hidrologia florestal,Manejo de Bacias Hidrograficas,Mata Atlantica},
  file = {D\:\\ZOTERO\\storage\\WDENLP5I\\Lorenzon et al. - 2013 - Precipitação efetiva e interceptação da chuva em u.pdf;D\:\\ZOTERO\\storage\\PN7755YZ\\rN7v3MkGSKXH8WsLt9kZxPM.html}
}

@article{
  title = {{{RAIN INTERCEPTION IN A SECONDARY FRAGMENT OF ARAUCARIA FOREST WITH FAXINAL}}, {{GUARAPUAVA-PR}}},
  author = {Thomaz, Edivaldo Lopes and Antoneli, Valdemir},
  year = {2015-Jul-Sep},
  journal = {CERNE},
  volume = {21},
  pages = {363--369},
  publisher = {UFLA - Universidade Federal de Lavras},
  issn = {0104-7760, 0104-7760, 2317-6342},
  doi = {10.1590/01047760201521031736},
  urldate = {2021-07-02},
  abstract = {ABSTRACT Forest management can alter the structure of vegetation (layer), particularly in areas used for pasture, such as the Faxinal areas in the south central region of Paran\'a, Brazil. Therefore, the aims of the present study were as follows: a) to assess rain interception in secondary forests; b) to estimate the maximum precipitation intercepted by the forest; and c) to discuss the possible implications of throughfall for the hydrologic processes of the secondary forest (Faxinal). Nine 20-cm-diameter rain gauges (314 cm2) were used. Rain gauges were distributed randomly throughout the forest and were successively rotated after a specific number of rainfalls. A total of 66 rainfall events of different volumes were recorded. We observed that an increase in rain volume tended to homogenize the rainfall interception rate in the forest. Consecutive rainfalls did not significantly influence the interception rate in the secondary forest. However, the interception in the secondary forest (10.5\%) was lower than the mean interception rate recorded in other Brazilian forests.},
  langid = {english},
  keywords = {forest hydrology,pasture,soil degradation,sustainability},
  file = {D\:\\ZOTERO\\storage\\QCG3ZP9K\\Thomaz and Antoneli - 2015 - RAIN INTERCEPTION IN A SECONDARY FRAGMENT OF ARAUC.pdf;D\:\\ZOTERO\\storage\\MRKN3WKB\\QCVPD5SBK3vX4YJb8kkCYfc.html}
}

@article{
