  publisher = {EarthArXiv},
  urldate = {2025-03-22},
  abstract = {In 2023, an unprecedented drought and heatwave severely impacted Amazon waters, leading to high mortality of fishes and river dolphins. Five of 10 lakes monitored showed exceptionally high daytime temperatures ({$>$}37{$^\circ$}C), with one large lake reaching up to 41{$^\circ$}C in the entire \textasciitilde 2-m deep water column, with up to 13{$^\circ$}C of diel variation. Modeling show that high solar radiation, reduced water depth and wind speed, and turbid waters are the main drivers of the high temperatures. This extreme heating of Amazon waters follows a long-term increase of 0.6{$^\circ$}C/decade revealed by satellite estimates across the region's lakes between 1990 and 2023. With ongoing climate change, temperatures that approach or exceed thermal tolerances for aquatic life are likely to become more common in tropical aquatic systems.},
  copyright = {CC-BY Attribution-No Derivatives 4.0 International},
  langid = {english},
  file = {D:\ZOTERO\storage\ZKGWH84E\Fleischmann et al. - 2024 - Extreme warming of Amazon waters in a changing climate.pdf}
}

