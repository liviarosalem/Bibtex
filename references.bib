@article{
  title = {Studies on the {{Water Relations}} of {{Pinus}} Sylvestris in {{Plantation Conditions}}. {{IV}}. {{Direct Observations}} on the {{Rates}} of {{Transpiration}}, {{Evaporation}} of {{Intercepted Water}}, and {{Evaporation}} from the {{Soil Surface}}},
  author = {Rutter, A. J.},
  year = 1966,
  journal = {Journal of Applied Ecology},
  volume = {3},
  number = {2},
  pages = {393--405},
  publisher = {[British Ecological Society, Wiley]},
  issn = {0021-8901},
  doi = {10.2307/2401261},
  urldate = {2020-09-25},
  abstract = {The total evaporation from a plantation of Pinus slyvestris at Crowthorne, Berkshire, was estimated on forty-four randomly chosen sample days during the 3 years 1957-59, from measurements of the water lost from isolated blocks of soil within the plantation, and of the loss of weight of detached branches or leaves, suspended in the places from which they had been removed, during the 10 min after they were detached. Experiments showed that the effects of detachment on the rate of water loss from branches and leaves was probably negligible in the conditions of these experiments. The branches or leaves were sampled so as to represent different layers of the canopy and different aspects. The rates of water loss from them were expressed per unit weight or leaf, and the amounts of leaf present per hectare in the plantation were determined by a sampling procedure, from which the pattern of change in the weight and area of the canopy could be determined. The dry weight of the foliage varies from 5000-6000 kg/ha at the end of winter to 9000-10000 kg/ha in summer, and the leaf area index (total surface) appears to vary seasonally between about 2{$\cdot$}5 and 4{$\cdot$}5. The total evaporation from the plantation exceeded EO (potential evaporation from an open water surface) on rainy days (when the foliage was wet). It was less than EO on rainless days from November to May but it was not significantly different from EO during June to October. The mean evaporation determined in this way was similar in amount to the mean evaporation estimated from the rainfall during the periods of soil water deficit in the 3 years.},
  file = {D:\ZOTERO\storage\I9TN9ATS\Rutter - 1966 - Studies on the Water Relations of Pinus sylvestris.pdf}
}

@article{
  title = {Rainfall Parameters Affect Canopy Storage Capacity under Controlled Conditions},
  author = {{Klamerus-Iwan}, Anna},
  year = 2015,
  month = mar,
  journal = {Forest Research Papers},
  volume = {75},
  number = {4},
  pages = {353--358},
  publisher = {Sciendo},
  doi = {10.2478/frp-2014-0032},
  urldate = {2020-09-26},
  abstract = {{$<$}section class="abstract"{$><$}h2 class="abstractTitle text-title my-1" id="d545e2"{$>$}Abstract{$<$}/h2{$><$}p{$>$} The subject of this research was the interception of precipitation, which is defined as the amount of water that can be retained by the entire surface of a tree. The aim was to measure the rate of interception under laboratory conditions in order to determine influential factors. To eliminate water absorption that would occur in living trees, we employed models of deciduous and coniferous trees enabling us to examine the effect of precipitation characteristics and the surface area individually. A sprinkler system that automatically recorded the amounts of water retained on the models was set up in the laboratory. Precipitation was simulated using 5 different intensities with 3 different raindrop sizes. {$<$}/p{$><$}p{$>$}Interception rates were affected by both, the intensity of the precipitation and raindrop size. The time required to reach maximum crown filling with water was variable and depended on plant surface parameters as well as simulated precipitation. The maximum water capacity of crowns was not a constant value even within one tree model, but changed depending on precipitation characteristics{$<$}/p{$><$}/section{$>$}},
  chapter = {Forest Research Papers},
  langid = {english},
  file = {D\:\\ZOTERO\\storage\\A87WV72A\\Klamerus-Iwan - 2015 - Rainfall parameters affect canopy storage capacity.pdf;D\:\\ZOTERO\\storage\\PAKYSCDK\\journals$002ffrp$002f75$002f4$002farticle-p353.html}
}

@article{
  title = {Rainfall Interception by Tree Crown and Leaf Litter: {{An}} Interactive Process},
  shorttitle = {Rainfall Interception by Tree Crown and Leaf Litter},
  author = {Li, Xiang and Xiao, Qingfu and Niu, Jianzhi and Dymond, Salli and McPherson, E. Gregory and van Doorn, Natalie and Yu, Xinxiao and Xie, Baoyuan and Zhang, Kebin and Li, Jiao},
  year = 2017,
  journal = {Hydrological Processes},
  volume = {31},
  number = {20},
  pages = {3533--3542},
  issn = {1099-1085},
  doi = {10.1002/hyp.11275},
  urldate = {2020-09-26},
  abstract = {Rainfall interception research in forest ecosystems usually focuses on interception by either tree crown or leaf litter, although the 2 components interact when rainfall occurs. A process-based study was conducted to jointly measure rainfall interception by crown and litter and the interaction between the 2 interception processes for 4 tree species (Platycladus orientalis and Pinus tabulaeformis represented needle-leaf species, and Quercus variabilis and Acer truncatum represented broadleaf species) at 3 simulated rainfall intensities (10, 50, and 100 mm hr-1). Results indicated that (a) crown and litter interception processes incorporated 3 phases: the dampening phase, the steady saturation phase, and the postrainfall drainage phase, but the dampening phase for litter interception usually lasted 30 min longer than for crown interception; (b) the maximum and minimum interception storage (Cmax and Cmin) for the crown were 0.63 and 0.36 mm on average, and litter Cmax and Cmin were 5.38 and 2.36 mm, respectively; (c) generally, crown and litter Cmax and Cmin increased when gross precipitation increased significantly (p {$<$} .05) from 10 to 100 mm; and (4) crown Cmax and Cmin for needle-species were 1.8 and 1.2 times larger than broadleaf species, whereas broadleaf litter showed the opposite, its Cmax and Cmin were 2.0 and 1.6 times larger than needle-leaf litter on average; however, no significant differences were observed in crown and litter Cmax and Cmin between species on per leaf area and litter thickness basis. Results were normalized by total leaf area and litter thickness to provide a way to scale up from young trees to mature forests. Overall, rainfall interception was affected by biotic and abiotic factors together and could be quantified via multiple linear regression functions.},
  copyright = {Copyright \copyright{} 2017 John Wiley \& Sons, Ltd.},
  langid = {english},
  keywords = {crown interception,gross precipitation,interception process,leaf area,litter interception,litter thickness},
  file = {D\:\\ZOTERO\\storage\\N5IZXZPL\\Li et al. - 2017 - Rainfall interception by tree crown and leaf litte.pdf;D\:\\ZOTERO\\storage\\C33GILDH\\hyp.html}
}

