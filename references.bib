  urldate = {2021-06-30},
  abstract = {This paper examines the feasibility of using a nuclear method to make non-destructive measurements of both fresh canopy mass and canopy surface-water storage. The theory of gamma-ray attenuation is developed for the field situation, and a preliminary experiment is described in which the accuracy of the canopy mass estimate is verified by comparison with a destructive measurement. By artificially saturating the canopy with water, a canopy storage capacity of 2.4 \textpm{} 0.6 mm is estimated for Sitka spruce of average height 12m.},
