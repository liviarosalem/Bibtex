@incollection{
  title = {Chapter 29 - {{Groundwater}} Recharge and Sustainability in {{Brazil}}},
  booktitle = {Global {{Groundwater}}},
  author = {Oliveira, Paulo Tarso S. and Lucas, Murilo Cesar and {de Faria Godoi}, Raquel and Wendland, Edson},
  editor = {Mukherjee, Abhijit and Scanlon, Bridget R. and Aureli, Alice and Langan, Simon and Guo, Huaming and McKenzie, Andrew A.},
  year = 2021,
  month = jan,
  pages = {393--407},
  publisher = {Elsevier},
  doi = {10.1016/B978-0-12-818172-0.00029-3},
  urldate = {2024-09-27},
  abstract = {In this chapter, we review the groundwater recharge studies developed in Brazil, discussing recharge values, methods, uncertainties, and sustainability of the groundwater use. Recharge rates are important to estimate sustainable groundwater abstraction and, consequently, to avoid groundwater depletion. We found few studies in Brazil on groundwater recharge; on the other hand, groundwater use has significantly increased in the last decade. Therefore there is a huge and important avenue to discuss groundwater sustainability in the country. It is crucial to conduct more investigations on groundwater recharge and its uncertainty estimates in different aquifers, land covers, and hydrometeorological conditions. Then, it will be possible to improve understanding about potential and limits of groundwater use in Brazil.},
  isbn = {978-0-12-818172-0},
  keywords = {Alter do Chao,Guarani,Serra Geral,Urucuia,water balance,water scarcity,water-table fluctuation},
  file = {D\:\\ZOTERO\\storage\\83KIBRAH\\Oliveira et al. - 2021 - Chapter 29 - Groundwater recharge and sustainability in Brazil.pdf;D\:\\ZOTERO\\storage\\FLQM3LZ8\\B9780128181720000293.html}
}

@article{businger1986,
  title = {Evaluation of the {{Accuracy}} with {{Which Dry Deposition Can Be Measured}} with {{Current Micrometeorological Techniques}}},
  author = {Businger, J. A.},
  year = 1986,
  month = aug,
  issn = {1520-0450},
  urldate = {2024-09-28},
  abstract = {By reviewing the physics of the processes leading to dry deposition in the atmospheric surface layer, a number of corrections and possible errors in the determination of the dry deposition fluxes are identified. The concept of deposition velocity is examined, its usefulness discussed, and some pitfalls are pointed out. An overview is given of the various micrometeorological methods with which dry deposition can be determined and some of their limitations are indicated. With this background a number of recent publications on dry deposition have been analyzed. It is apparent that in most cases a more complete documentation is needed of the structure of the surface layer and the adjacent planetary boundary layer. Errors related to advection and entrainment are especially difficult or impossible to assess because of inadequate information about the surroundings and the height of the boundary layer.},
  chapter = {Journal of Applied Meteorology and Climatology},
  langid = {english},
  file = {D:\ZOTERO\storage\LTVJAMQB\Businger - 1986 - Evaluation of the Accuracy with Which Dry Deposition Can Be Measured with Current Micrometeorologica.pdf}
}

