@incollection{
  title = {Climate {{Change}} and {{Biodiversity}} in the {{Atlantic Forest}}: {{Best Climatic Models}}, {{Predicted Changes}} and {{Impacts}}, and {{Adaptation Options}}},
  shorttitle = {Climate {{Change}} and {{Biodiversity}} in the {{Atlantic Forest}}},
  booktitle = {The {{Atlantic Forest}}: {{History}}, {{Biodiversity}}, {{Threats}} and {{Opportunities}} of the {{Mega-diverse Forest}}},
  author = {Vale, Mariana M. and Arias, Paola A. and Ortega, Geusep and Cardoso, Manoel and Oliveira, Beatriz F. A. and Loyola, Rafael and Scarano, Fabio R.},
  editor = {Marques, Marcia C. M. and Grelle, Carlos E. V.},
  year = 2021,
  pages = {253--267},
  publisher = {Springer International Publishing},
  address = {Cham},
  doi = {10.1007/978-3-030-55322-7_12},
  urldate = {2024-08-12},
  abstract = {Ongoing anthropogenic climate change is becoming one of the major threats to biodiversity. Studies that aim at projecting the future impacts of ongoing climate change on biodiversity should use general circulation~models (GCMs) that show a good performance in the region of study, an information that is lacking for the Atlantic Forest. Here, we evaluated the performance of different GCMs over the Atlantic Forest, describe the predicted climatic changes for the regions based on the best performing GCMs, review the literature on observed and predicted impacts of climate change on the Atlantic Forest biodiversity, and discuss adaptation strategies to reduce the negative impacts of climate change on the region's biodiversity.},
  isbn = {978-3-030-55322-7},
  langid = {english},
  keywords = {Ecosystem-based adaptation,General circulation models,Restoration,Species conservation,Species distribution,Speciesextinction},
  file = {D:\ZOTERO\storage\5BKHMUIT\Vale et al. - 2021 - Climate Change and Biodiversity in the Atlantic Fo.pdf}
}

