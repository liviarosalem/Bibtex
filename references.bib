  author = {Pedrosa, Rafael Alves and Nunes, Danilo},
  year = 2019,
  month = aug,
  journal = {Revista Paid\'ei@ - Revista Cient\'ifica de Educa\c c\~ao a Dist\^ancia},
  volume = {11},
  number = {20},
  issn = {19826109},
  urldate = {2021-05-28},
  abstract = {A evas\~ao em cursos da modalidade a dist\^ancia \'e um dos principais obst\'aculos enfrentados pelas institui\c c\~oes. Nesse cen\'ario, se incluem os cursos superiores que vem sendo ofertados pela Universidade Virtual do Estado de S\~ao Paulo -- UNIVESP. Este trabalho teve como objetivo analisar as causas da evas\~ao em cursos superiores ofertados na modalidade a dist\^ancia. Para tanto, 100 alunos evadidos desses cursos completaram, de maneira online, perfil social, comportamento e atitudes do aluno em rela\c c\~ao a cursos a dist\^ancia s\~ao abordados no question\'ario. Os resultados apontam que uma parcela importante dos evadidos realizava outras tarefas concomitantes com o curso; ainda exp\~oem que dos evadidos boa parte dos entrevistados apresentava dificuldades de itera\c c\~ao com as plataformas utilizadas no processo de aprendizagem, al\'em de mapeamento do perfil social destes indiv\'iduos. Como conclus\~oes est\~ao: o fato de que o EaD \'e uma realidade e conforme aponta este estudo com vi\'es de crescimentos acentuado no pr\'oximos anos, mas tamb\'em indica a necessidade de evolu\c c\~ao nos processos e na rela\c c\~ao com os alunos possibilitando n\~ao somente seu acesso ao EaD mas seu efetivo aproveitamento e perman\^encia nos cursos e institui\c c\~oes, sejam elas p\'ublicas ou privadas que ofere\c cam essa modalidade de ensino, e ainda a necessidade da realiza\c c\~ao de novos estudos que possam dar continuidade ao mapeamento e apontamento de  solu\c c\~oes \`a inclus\~ao ou exclus\~ao de itens que aumentem a confiabilidade do EaD e minimizem os fatores identificados como causadores da evas\~ao.},
  copyright = {Direitos autorais 2019 Revista Paid\'ei@ - Revista Cient\'ifica de Educa\c c\~ao a Dist\^ancia},
  langid = {portuguese},
  keywords = {EaD,Ensino Superior,Evasao},
