  shorttitle = {Technical Note},
  author = {Schilperoort, Bart and {Coenders-Gerrits}, Miriam and Luxemburg, Willem and Jim{\'e}nez Rodr{\'i}guez, C{\'e}sar and Cisneros Vaca, C{\'e}sar and Savenije, Hubert},
  year = 2018,
  month = jan,
  journal = {Hydrology and Earth System Sciences},
