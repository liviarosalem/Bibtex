@article{
  title = {{A PRESENCIALIDADE EM EDUCA\c C\~AO A DIST\^ANCIA: CAMINHO PARA A CONSTRU\c C\~AO DE UMA PEDAGOGIA DA AUTONOMIA}},
  shorttitle = {{A PRESENCIALIDADE EM EDUCA\c C\~AO A DIST\^ANCIA}},
  author = {Frighetto, Gisele Novaes and de Almeida, Tatiana Lima and de Freitas, Alessandra Demite Gon{\c c}alves},
  year = 2020,
  month = aug,
  journal = {Anais do CIET:EnPED:2020 - (Congresso Internacional de Educa\c c\~ao e Tecnologias \textbar{} Encontro de Pesquisadores em Educa\c c\~ao a Dist\^ancia)},
  issn = {2316-8722},
  urldate = {2021-05-28},
  abstract = {Resumo 					O presente trabalho faz parte de uma pesquisa em desenvolvimento que apresenta como objetivo o estudo da presencialidade na Educa\c c\~ao a Dist\^ancia, com enfoque na atua\c c\~ao de mediadores com o intuito de perceber como a interlocu\c c\~ao e a rela\c c\~ao intersubjetiva por eles estabelecida em atividades ass\'incronas, no ambiente virtual de aprendizagem, pode resultar em maior engajamento e autonomia dos discentes, bem como em um ambiente de educa\c c\~ao humanizado. O referencial te\'orico foi pautado nos conceitos de presencialidade, sociointeracionismo (Vygotsky), interativismo (L\'evy), pr\'aticas das atividades livres (Freinet) e na pedagogia da autonomia (Freire). Trata-se de uma pesquisa de natureza quantitativa e qualitativa que, al\'em do levantamento bibliogr\'afico, contemplou dois estudos de caso em uma institui\c c\~ao p\'ublica de ensino superior do Estado de S\~ao Paulo. Esses estudos consistiram na an\'alise da atua\c c\~ao dos mediadores em duas disciplinas de gradua\c c\~ao no primeiro bimestre de 2020 e da resposta dos alunos \`a presen\c ca dos facilitadores de aprendizagem nos f\'oruns de discuss\~ao e de d\'uvidas no ambiente virtual. Entende-se que a atua\c c\~ao desses mediadores estimula a participa\c c\~ao dos educandos quantitativamente e qualitativamente e, com base nas postagens examinadas, que o papel docente que os primeiros exercem pode resultar em maior engajamento e autonomia dos discentes. Acredita-se que o estudo em desenvolvimento se far\'a relevante para reflex\~oes acerca da presencialidade, aqui entendida como caminho para uma pedagogia da autonomia na EaD.},
  copyright = {Copyright (c)},
  langid = {portuguese},
  file = {D\:\\ZOTERO\\storage\\WWV92JW4\\Frighetto et al. - 2020 - A PRESENCIALIDADE EM EDUCAÇÃO A DISTÂNCIA CAMINHO.pdf;D\:\\ZOTERO\\storage\\GQRIDFUT\\1040.html}
}

