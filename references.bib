@article{
  title = {{UTILIZA\c C\~AO DO MODELO CANEGRO PARA ESTIMATIVA DE CRESCIMENTO DA CANA-DE-A\c C\'UCAR IRRIGADA E N\~AO IRRIGADA PARA AS REGI\~OES DE GURUPI -- TO E TERESINA -- PI}},
  author = {Barros, Allan Cunha and Coelho, Rubens Duarte and Marin, F{\'a}bio R. and Polzer, Dorothee L. and Netto, Antenor de O. Aguiar},
  year = 2012,
  month = feb,
  journal = {IRRIGA},
  volume = {17},
  number = {2},
  pages = {189--207},
  issn = {1808-8546},
  doi = {10.15809/irriga.2012v17n2p189},
  urldate = {2025-10-15},
  abstract = {1 RESUMO   Na produ\c c\~ao da cana-de-a\c c\'ucar, a irriga\c c\~ao \'e empregada mais intensivamente em novas \'areas de expans\~ao onde h\'a insufici\^encia ou m\'a distribui\c c\~ao temporal de chuvas. As novas e promissoras \'areas para plantio de cana-de-a\c c\'ucar est\~ao localizadas nos estados de Maranh\~ao, Piau\'i e Tocantins. No entanto, a realiza\c c\~ao de experimentos, visando fornecer informa\c c\~oes de produtividade na tomada de decis\~ao, s\~ao onerosos e demoram muito tempo, por esse motivo, os modelos fisiol\'ogicos de simula\c c\~ao tornam-se ferramentas importantes, j\'a que atrav\'es deles \'e poss\'ivel estimar a~ produtividade de uma cultura, em diferentes condi\c c\~oes clim\'aticas, sob diferentes \'epocas de plantio e colheita e sob diferentes m\'etodos de manejo adotado. Assim, o objetivo do trabalho foi gerar informa\c c\~oes sobre a produtividade potencial da cana-de-a\c c\'ucar nas cidades de Gurupi -- TO e Teresina -- PI, com plantio e colheita em diferentes datas, atrav\'es de estimativas de crescimento da cultura utilizando o CANEGRO/DSSAT e determinar o efeito da irriga\c c\~ao sob a produtividade. Os cen\'arios foram baseados em 4 datas de plantio (15 de janeiro, 15 de mar\c co, 15 de setembro e 15 de novembro)~ x 2 \'epocas de colheita (1 e 1,5 anos) x 2 sistemas (irrigado e sequeiro), totalizando 16 cen\'arios por cidade. Assim, foi poss\'ivel verificar que a produtividade em Gurupi -- TO variou entre 102 a 208 Mg.ha-{$^1$}, e em Teresina de 86 a 174 Mg.ha-{$^1$}, no entanto, estas foram superestimadas nos plantios em sequeiro; e a irriga\c c\~ao possibilitou o plantio em diferentes \'epocas do ano, aumentando a produ\c c\~ao de a\c c\'ucar em no m\'inimo 52\% em Gurupi e 42\% em Teresina. ~ PALAVRA-CHAVE: Dssat, simula\c c\~ao de crescimento, irriga\c c\~ao em cana ~ ~ BARROS, A. C; COELHO, R. D.; MARIN, F. R.; POLZER, D. L.; AGUIAR NETTO, A. de O. USING THE MODEL CANEGRO TO ESTIMATE GROWTH OF SUGARCANE IRRIGATED AND NOT IRRIGATED FOR THE REGIONS OF GURUPI - TO AND TERESINA - PI ~ ~ ~ ~ ~ 2~ ABSTRACT   The irrigation is come to used, in the sugarcane production, in the expansion areas where there is insufficient or poor distribution of rainfall. The promising and new areas for sugarcane are located in the states of Maranh\~ao, Piau\'i and Tocantins. However, performing experiments in order to yield information in decision making, it is expensive and time-intensive, therefore, the models become important tools, since in it is possible to estimate the yield in different climatic conditions, under different planting, harvesting seasons and under different management practices adopted. Thus, the aim was to generate information about the potential productivity of sugarcane in the cities of Gurupi - TO and Teresina - PI, with planting and harvesting at different dates, trough estimating crop growth using the CANEGRO / DSSAT and to determine the effect of irrigation on productivity.~The scenarios were based on four planting dates (January 15, March 15, September 15 and November 15) x 2 harvest times (1 and 1.5 years) x 2 systems (irrigated and rainfed), totaling 16 scenarios for city. Thus, it was possible to verify yield obtained in Gurupi was values between 102 to 208 Mg ha-{$^1$}, and 86 to 174 Mg ha-{$^1$} in Teresina, however, thess datas were overestimated in rainfed crops; and the irrigation possible the planting at different dates of the year, increasing the sugar production in at least 52\% in Gurupi and 42\% in Teresina. ~ KEYWORD: DSSAT, growth simulation, irrigation in sugarcane},
  copyright = {Copyright (c)},
  langid = {portuguese},
  file = {D:\ZOTERO\storage\96AMLWI2\Barros et al. - 2012 - UTILIZAÇÃO DO MODELO CANEGRO PARA ESTIMATIVA DE CRESCIMENTO DA CANA-DE-AÇÚCAR IRRIGADA E NÃO IRRIGAD.pdf}
}

@article{
  title = {Predicting Soybean Evapotranspiration and Crop Water Productivity for a Tropical Environment Using the {{CSM-CROPGRO-Soybean}} Model},
