@article{fleischmann2024,
  title = {Extreme Warming of {{Amazon}} Waters in a Changing Climate},
  author = {Fleischmann, Ayan Santos and Papa, Fabrice and Hamilton, Stephen and Melack, John and Forsberg, Bruce and Val, Adalberto and Collischonn, Walter and Laipelt, Leonardo and Rossi, J{\'u}lia and de Andrade, Bruno Comini and Mendel, Bruna and Alves, Priscila and Glorize, Maiby and Custodio, Lady and Gomes, Maria Cec{\'i}lia and Hymans, D{\'e}bora and Keppe, Isabela and Mendes, Raize and Gomes, Renan and Silva, Paula and Vieira, Camila and Xavier, Rodrigo and Zumak, Andr{\'e} and Ruhoff, Anderson and Zhou, Wencai and MacIntyre, Sally and Martins, Eduardo and Filizola, Naziano and Marinho, Rog{\'e}rio and Severo, Ednaldo and Frias, Mariana and Oliveira, Renata and Lauretto, Lucas and Gravena, Waleska and Coelho, Andr{\'e} and Perez, Hilda and Mota, Susana and Nasser, Michel and Moreira, Daniel and Santos, Leandro and Peleja, Jos{\'e} Reinaldo and Marmontel, Miriam},
  year = 2024,
