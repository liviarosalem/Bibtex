@article{
  title = {{Forma\c c\~oes sav\^anicas mundiais: uma breve descri\c c\~ao fitogeogr\'afica}},
  shorttitle = {{Forma\c c\~oes sav\^anicas mundiais}},
  author = {Pinheiro, Marcelo Henrique Ongaro},
  year = 2010,
  month = dec,
  journal = {Brazilian Geographical Journal},
  volume = {1},
  number = {2},
  issn = {2179-2321},
  urldate = {2021-04-10},
  abstract = {Resumo 					Forma\c c\~oes sav\^anicas podem ser encontradas em regi\~oes tropicais e subtropicais em todo mundo. S\~ao caracterizadas pela ocorr\^encia de esp\'ecies arbostivo-arb\'oreas e herb\'aceas, especialmente as pertencentes aos g\^eneros Poaceae e Cyperaceae, em intensidades de cobertura variadas, desde campos graminosos, a forma\c c\~oes com aspecto florestal, como o miombo, no Sud\~ao, e o cerrad\~ao, no Brasil. Normalmente, forma\c c\~oes sav\^anicas ocupam solos distr\'oficos e arenosos, em regi\~oes cujo clima \'e composto por esta\c c\~oes chuvosa e seca definidas. A origem dessas forma\c c\~oes \'e atribu\'ida a diferentes fatores, e.g., influ\^encias ed\'afica, clim\'atica, antr\'opica, atrav\'es de queimadas. Contudo, \'e poss\'ivel que a intera\c c\~ao de fatores, nos per\'iodos Terci\'ario e Quatern\'ario, possa ter contribu\'ido para o desenvolvimento de forma\c c\~oes e fisionomias sav\^anicas, como as encontradas, por exemplo, no cerrado sensu lato. Este trabalho de revis\~ao teve por objetivo fornecer informa\c c\~oes fitogeogr\'aficas que possibilitem a caracteriza\c c\~ao das principais forma\c c\~oes sav\^anicas mundiais e brasileiras.},
  copyright = {Copyright (c)},
  langid = {portuguese},
  file = {D\:\\ZOTERO\\storage\\37D48MYT\\Pinheiro - 2010 - Formações savânicas mundiais uma breve descrição .pdf;D\:\\ZOTERO\\storage\\AL5RY6BA\\8205.html}
}

@article{
  title = {{Influ\^encia do clima na din\^amica de serrapilheira em uma floresta estacional semidecidual em Valen\c ca, RJ, Brasil}},
  author = {Bianchi, Miriam de Oliveira and Scoriza, Rafael Nogueira},
  year = 2016,
  volume = {14},
  pages = {5},
  abstract = {Climate influence on litter dynamics in a seasonal semideciduous forest in Valen\c ca municipality, Rio de Janeiro state, Brazil). Understanding the factors underlying litter dynamics is of great importance to fully comprehend the development of forest ecosystems. Thus, we aimed to evaluate the influence of precipitation and temperature on litterfall and litter storage and decomposition in a seasonal semideciduous forest in Serra da Conc\'ordia, Valen\c ca municipality, Rio de Janeiro state, Brazil. Litter was evaluated throughout 12 months in a forest remnant, using suspended tapered collectors for litterfall and 0.25 m2 squares for soil litter stock. The amount of litter found in the remaining forest was lower than that reported in the literature, with higher values at the end of the dry season. Temperature and precipitation negatively influenced litterfall and litter stock, with effects showing after two to four months. Knowing the relationships between litter and climate conditions aids in understanding and using litter as an indicator in forest areas. Thereby, it also enables the evaluation on the possible recovery of ecological functions in a given environment.},
  langid = {portuguese},
  file = {D:\ZOTERO\storage\EW8SH9AL\Bianchi and Scoriza - 2016 - Influência do clima na dinâmica de serrapilheira e.pdf}
}

