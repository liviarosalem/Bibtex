@article{
  title = {{A Forma\c c\~ao de Tutores no Centro Paula Souza e Univesp: um processo cont\'inuo e abrangente}},
  shorttitle = {{A Forma\c c\~ao de Tutores no Centro Paula Souza e Univesp}},
  author = {Jr, Dilermando Piva and Gara, Elizabete Briani M. and Netto, Marcio L. Andrade and Loyolla, Waldomiro P. D. de C.},
  year = 2013,
  journal = {Revista EducaOnline},
  volume = {7},
  number = {2},
  pages = {34--55},
  issn = {1983-2664},
  urldate = {2021-05-27},
  abstract = {O processo de forma\&ccedil;\&atilde;o de tutores (mediadores) para EAD envolve uma s\&eacute;rie de etapas, dentre elas a: avalia\&ccedil;\&atilde;o do perfil e curr\&iacute;culo, forma\&ccedil;\&atilde;o para a modalidade, avalia\&ccedil;\&atilde;o do processo formativo, defini\&ccedil;\&atilde;o de atribui\&ccedil;\&otilde;es e modelo de intera\&ccedil;\&atilde;o de professores-mediadores online e presencial. Com o intuito de contribuir com outras institui\&ccedil;\&otilde;es e compartilhar o trabalho que est\&aacute; sendo desenvolvido no contexto do Centro Paula Souza e da Univesp \&ndash; Universidade Virtual do Estado de S\&atilde;o Paulo apresentamos o modelo, a metodologia de forma\&ccedil;\&atilde;o de mediadores e a avalia\&ccedil;\&atilde;o do processo formativo com base nos dados coletados nas capacita\&ccedil;\&otilde;es realizadas em 2010, 2011 e 2012. Os resultados coletados sugerem uma avalia\&ccedil;\&atilde;o positiva, e alguns indicativos de melhorias para as pr\&oacute;ximas etapas de forma\&ccedil;\&atilde;o. Pretendemos assim, que se torne um ponto de partida para reflex\&atilde;o e desenvolvimento desse tema amplo e cada vez mais complexo, principalmente no \&acirc;mbito das Institui\&ccedil;\&otilde;es P\&uacute;blicas de Ensino de Gradua\&ccedil;\&atilde;o e P\&oacute;s-Gradua\&ccedil;\&atilde;o.    Palavras-chave:  Forma\&ccedil;\&atilde;o de Mediadores, Mediadores, Tutores, Centro Paula Souza, Univesp.      Abstract    The training process of the tutors (mediators) for EAD involves a series of steps, among them: profile and curriculum evaluation, specific training, formative assessment of the formative process, setting assignments and interaction model of professors and tutors. Aiming to contribute to other institutions and share the work that is being developed in the context of Centro Paula Souza and UNIVESP - Virtual University of S\&atilde;o Paulo are presented the model, the methodology of training of tutors and evaluation of the training process based the data collected in the training conducted in 2010, 2011 and 2012. Our results suggest a positive evaluation, and some indications of improvements for the next stages of training. Therefore we wish it to become a starting point for reflection and development of this broad topic and increasingly complex, particularly within the Public Institutions of Undergraduate and Graduate Studies.    Keywords:  Training of tutors, Tutors, Centro Paula Souza, Univesp.},
  copyright = {Direitos autorais},
  langid = {portuguese},
  file = {D\:\\ZOTERO\\storage\\U5PI62PS\\Jr et al. - 2013 - A Formação de Tutores no Centro Paula Souza e Univ.pdf;D\:\\ZOTERO\\storage\\TFKMFVNZ\\index.html}
}

@article{
  title = {{COMPET\^ENCIAS PEDAG\'OGICAS: O ``OLHAR'' DO TUTOR PRESENCIAL DO SISTEMA DA UNIVERSIDADE ABERTA DO BRASIL}},
  shorttitle = {{COMPET\^ENCIAS PEDAG\'OGICAS}},
  author = {dos Santos, Rosimeire and Lahan, Stelamary Aparecida Despincieri and Zaniolo, Leandro Osni},
  year = 2012,
  month = oct,
  journal = {SIED:EnPED - Simp\'osio Internacional de Educa\c c\~ao a Dist\^ancia e Encontro de Pesquisadores em Educa\c c\~ao a Dist\^ancia 2012},
  volume = {0},
  number = {0},
  issn = {2316-8722},
  urldate = {2021-05-27},
  abstract = {O presente artigo objetiva verificar o ``olhar'' do tutor presencial no que se refere \`as compet\^encias pedag\'ogicas exigidas para o exerc\'icio da fun\c c\~ao pelo Sistema da Universidade Aberta do Brasil. Para este estudo utilizou-se da metodologia qualitativa e quantitativa analisando os seguintes aspectos: descri\c c\~ao do papel do tutor no seu sentido mais amplo; a import\^ancia do seu papel; as diversas compet\^encias necess\'arias para a pr\'atica; an\'alise dos documentos institucionais utilizados para treinamento e capacita\c c\~ao e a vis\~ao dos tutores sobre a dimens\~ao pedag\'ogica. Para levantamento da import\^ancia que os tutores delegam para a compet\^encia pedag\'ogica aplicou-se um question\'ario on-line pela ferramenta Google Doc's. Ap\'os a an\'alise dos dados foi poss\'ivel observar que as compet\^encias pedag\'ogicas propostas s\~ao de essencial relev\^ancia na a\c c\~ao dos tutores, por\'em podemos inferir que conhecer qual a relev\^ancia dada pelo tutor a essas compet\^encias amplia o conhecimento sobre a pr\'atica da tutoria e pode auxiliar os processos de forma\c c\~ao do tutor.},
  langid = {portuguese},
  keywords = {Competencia Pedagogica,Educacao a Distancia.,Tutoria},
  file = {D\:\\ZOTERO\\storage\\ZVCIQ7P3\\Santos et al. - 2012 - COMPETÊNCIAS PEDAGÓGICAS O “OLHAR” DO TUTOR PRESE.pdf;D\:\\ZOTERO\\storage\\FP9KA4TE\\176.html}
}

