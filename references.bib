}

@phdthesis{
  type = {{text}},
  title = {{Monitoramento e modelagem do processo de intercepta\c c\~ao em \'area de Cerrado stricto sensu}},
  author = {Rosalem, L{\'i}via Malacarne Pinheiro},
  year = 2021,
  month = oct,
  doi = {10.11606/T.18.2021.tde-22122021-102301},
  urldate = {2022-03-31},
  abstract = {A intercepta\c c\~ao da chuva pela floresta e sua subsequente evapora\c c\~ao constitui uma parte importante do ciclo hidrol\'ogico. Entretanto, devido principalmente a dificuldade em realizar o monitoramento direto, o processo de intercepta\c c\~ao pela serrapilheira tem sido geralmente desconsiderado nos balan\c cos h\'idricos. Por isso, os modelos de intercepta\c c\~ao mais aplicados concentram-se apenas no processo de intercepta\c c\~ao do dossel e do caule, e desconsideram a intercepta\c c\~ao pela serrapilheira, o que resulta em valores subestimados de evapora\c c\~ao total. O objetivo principal deste trabalho foi analisar os processos de intercepta\c c\~ao atrav\'es da quantifica\c c\~ao da intercepta\c c\~ao pelo dossel, troncos e pela serrapilheira de uma \'area experimental de Cerrado stricto sensu a fim de aprimorar o balan\c co h\'idrico local. Para isso foram monitorados entre Junho de 2017 a Fevereiro de 2020 algumas vari\'aveis meteorol\'ogicas, a precipita\c c\~ao total e interna, a infiltra\c c\~ao e o escoamento dos troncos atrav\'es de uma rede de equipamentos manuais e autom\'aticos, al\'em do monitoramento direto e autom\'atico da intercepta\c c\~ao pela serrapilheira e evapora\c c\~ao do solo. Ainda, entre outubro de 2018 e setembro 2019 foi realizado o monitoramento da produ\c c\~ao mensal de serrapilheira a partir de 37 coletores dispostos em 9 transectos na \'area de estudo. Como foram observados acr\'escimos no armazenamento da serrapilheira durante alguns per\'iodos noturnos, foi verificada a possibilidade de intercepta\c c\~ao de orvalho pela serrapilheira. Para uma melhor an\'alise dos processos de intercepta\c c\~ao nos eventos de precipita\c c\~ao, foram desenvolvidas vers\~oes adaptadas dos modelos de intercepta\c c\~ao de Rutter e de Gash, denominadas RA e GA, afim de que a intercepta\c c\~ao pela serrapilheira fosse inclu\'ida. Como resultados do monitoramento, a precipita\c c\~ao interna, a infiltra\c c\~ao e o escoamento dos troncos corresponderam a 72\%, 60\% e},
  langid = {brazilian},
  school = {Universidade de S\~ao Paulo},
  file = {D\:\\ZOTERO\\storage\\6VTHKTVJ\\Rosalem - 2021 - Monitoramento e modelagem do processo de intercept.pdf;D\:\\ZOTERO\\storage\\TQVC92WR\\pt-br.html}
}

@article{guarnier2021,
  title = {Spatial--Temporal Variability and Extreme Climate Indices of Precipitation in a Coastal Watershed of Southeastern {{Brazil}}},
  author = {Guarnier, Let{\'i}cia and Barroso, Gilberto Fonseca},
  year = 2021,
  month = oct,
  journal = {Environmental Monitoring and Assessment},
  volume = {193},
  number = {11},
  pages = {742},
  issn = {1573-2959},
  doi = {10.1007/s10661-021-09491-3},
  urldate = {2022-04-06},
  abstract = {The analysis of multi-temporal and spatial trends of rainfall in a river basin is an essential approach for water resource planning and management approach. In this study, a combination of trend analysis and spatial--temporal variability of the rainfall for 1970--2017 was applied to examine rainfall distribution patterns in a coastal watershed, Santa Maria da Vit\'oria River Basin (southeastern Brazil). Data from 42 meteorological stations were analyzed using kriging as a geostatistical tool for point data interpolation. Trends in rainfall were computed using the RClimDex package with eleven extreme climate indices. The results have shown spatial and temporal rainfall variability, with drought events becoming more persistent in recent years in the upper sector of the basin, where agricultural land use prevails. Water shortage may impact crops and threatening the water supply and hydropower production. Trend analysis suggests that the annual total wet-day precipitation (PRCPTOT) increases in the coastal section and decreases in the upper basin sector. Consecutive dry days (CDD) and consecutive wet days (CWD) show a strong positive tendency in the lower basin section, where the metropolitan area is located, flooding risks increase in response to positive trends of intensive short-term rainfall events. These results support managers developing and planning sustainability strategies to assure water security and subsidize adaptative responses to extreme hydrological events.},
  langid = {english},
  file = {D:\ZOTERO\storage\MUPFRA6P\Guarnier and Barroso - 2021 - Spatial–temporal variability and extreme climate i.pdf}
}

