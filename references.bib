}

@article{
  title = {{As m\'idias sociais no contexto da educa\c c\~ao superior}},
  author = {Celestino, Marcelo Salvador and Colloca, Nicolas Antonio Messias dos Santos and Junior, Luiz Francisco Ananias and Albino, Jo{\~a}o Pedro and Valente, V{\^a}nia Cristina Pires Nogueira},
  year = 2019,
