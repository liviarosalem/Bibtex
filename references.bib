  langid = {portuguese},
  keywords = {Agricultural Census,cattle ranching,logit model,mechanization,technology},
  file = {D:\ZOTERO\storage\7P6AADMW\Rodrigues et al. - 2022 - Determinants for agricultural fertilizer use in Brazilian Amazon a one-decade analysis.pdf}
}

